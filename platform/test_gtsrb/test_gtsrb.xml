<?xml version="1.0" ?>
<rvx>
	<platform>
		<name>test_gtsrb</name>
		<status>described</status>
		<spec>
      <define>
        <name>sram_size</name>
        <value>64kB</value>
      </define>
      <define>
        <name>include_timer</name>
        <value type="bool">True</value>
      </define>
      <define>
        <name>include_slow_dram</name>
        <value type="bool">True</value>
      </define>
      <define>
        <name>num_led_checker</name>
        <value>1</value>
      </define>
      <define>
        <name>include_arducam</name>
        <value type="bool">True</value>
      </define>
      <define>
        <name>include_oled_rgb</name>
        <value type="bool">True</value>
      </define>
      <define>
        <name>include_spi_flash</name>
        <value type="bool">True</value>
      </define>
      <define>
        <name>include_plic</name>
        <value type="bool">True</value>
      </define>
      <define>
        <name>num_spi_user</name>
        <value>1</value>
      </define>
      <define>
        <name>num_uart_user</name>
        <value>1</value>
      </define>
    </spec>

    <ip_instance>
      <name>i_dca_neugemm00</name>
      <library_name>dca_neugemm_mmiox_mlsu</library_name>
      <parameter>
        <id>TENSOR_PARA</id>
        <value>32</value>
      </parameter>
      <parameter>
        <id>MATRIX_SIZE_PARA</id>
        <value>8</value>
      </parameter>
      <parameter>
        <id>INST_FIFO_DEPTH</id>
        <value>8</value>
      </parameter>
    </ip_instance>

    <clock_info>
      <define>
        <name>clk_system</name>
        <value type="dec">100000000</value>
      </define>
      <define>
        <name>clk_dca_core</name>
        <value type="dec">100000000</value>
      </define>
    </clock_info>

		<ip_instance>
			<name>i_main_core</name>
			<library_name>rvc_rocket_big</library_name>
		</ip_instance>

    <sw_define>
      <use_reuse_memory_allocator type="bool">True</use_reuse_memory_allocator>
      <caching_most type="bool">True</caching_most>
      <use_profiling type="bool">True</use_profiling>
      <silent_for_profiling type="bool">False</silent_for_profiling>
    </sw_define>

    <sim_define>
      <simulate_spi_flash type='bool'>False</simulate_spi_flash>
    </sim_define>

    <signal>
      <name>oled_bw_sclk</name>
      <width>1</width>
      <port>output</port>
      <user_dependent/>
    </signal>
    <signal>
      <name>oled_bw_sdin</name>
      <width>1</width>
      <port>output</port>
      <user_dependent/>
    </signal>

    <gpio>
      <name>oled_bw_dc</name>
      <width>1</width>
    </gpio>
    <gpio>
      <name>oled_bw_res</name>
      <width>1</width>
    </gpio>
    <gpio>
      <name>oled_bw_vbat</name>
      <width>1</width>
    </gpio>
    <gpio>
      <name>oled_bw_vdd</name>
      <width>1</width>
    </gpio>
    <gpio>
      <name>btnc</name>
      <width>1</width>
    </gpio>

    <signal>
      <name>cls_uart_tx</name>
      <width>1</width>
      <port>output</port>
      <user_dependent/>
    </signal>

    <signal>
      <name>cls_uart_rx</name>
      <width>1</width>
      <port>input</port>
      <user_dependent/>
    </signal>

	</platform>
</rvx>
